/*
 * Platform: GeeksforGeeks
 * Problem: Program to find sum of elements in a given array
 *
 * Approach:
 * 1. Initialize a variable sum = 0.
 * 2. Traverse the array using a for loop.
 * 3. Add each element to sum.
 * 4. Return the final sum.
 *
 * Time Complexity: O(n)
 * Space Complexity: O(1)
 */

class Solution {
    public int arraySum(int arr[]) {

        int sum = 0;
        int n = arr.length;

        for (int i = 0; i < n; i++) {
            sum = sum + arr[i];
        }

        return sum;
    }
}


